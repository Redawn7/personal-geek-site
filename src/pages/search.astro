---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search all posts, notes, life notes, and projects. 搜索全站。" path="/search">
  <section class="shell" style="padding: 48px 0 96px;">
    <div style="margin-bottom: 24px;">
      <p class="mono" style="color: var(--green); font-size: 12px; margin: 0 0 8px;">SEARCH / 搜索</p>
      <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 0.96; margin: 0;">Search</h1>
      <p style="color: var(--muted); margin: 12px 0 0; font-size: 1rem;">Find anything across Blog, Notes, Life, and Lab.</p>
    </div>
    <div id="pagefind-search" role="search" aria-label="Search content" style="max-width: 760px;"></div>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var el = document.getElementById('pagefind-search');
    if (!el) return;
    var s = document.createElement('script');
    s.src = '/pagefind/pagefind-ui.js';
    s.onload = function () {
      new PagefindUI({
        element: '#pagefind-search',
        showSubResults: true,
        autofocus: true,
      });
    };
    s.onerror = function () {
      el.innerHTML = '<p class="mono" style="color: var(--muted); font-size: 12px;">Search is not ready in preview mode. Try the live site.</p>';
    };
    document.head.appendChild(s);
  });
</script>
