---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 – Not Found" description="This page does not exist." path="/404">
  <section class="shell" style="padding: 96px 0; text-align: center;">
    <p class="mono" style="color: var(--danger); font-size: 12px; margin: 0 0 16px;">ERROR 404</p>
    <h1 style="font-size: clamp(3rem, 8vw, 6rem); line-height: 0.96; margin: 0 0 16px;">Not Found</h1>
    <p style="color: var(--muted); margin: 0 0 32px; font-size: 1rem; max-width: 480px; margin-left: auto; margin-right: auto;">
      The signal you're looking for doesn't exist or has been moved.
    </p>
    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a class="mono" href="/archive" style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border: 1px solid var(--line); border-radius: 4px; color: var(--text); font-size: 12px; text-decoration: none; transition: border-color 0.15s;">Archive</a>
      <a class="mono" href="/search" style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border: 1px solid var(--line); border-radius: 4px; color: var(--text); font-size: 12px; text-decoration: none; transition: border-color 0.15s;">Search</a>
    </div>
  </section>
</BaseLayout>
