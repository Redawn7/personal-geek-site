---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { publishedNewestFirst } from '../../lib/content';
import { mediaUrl } from '../../lib/media';

const life = publishedNewestFirst(await getCollection('life'));
---

<BaseLayout title="Life" description="Daily memories, places, and moods. 生活记录。" path="/life">
  <section class="shell life-shell">
    <div class="life-hero ink-panel">
      <div>
        <p class="mono">ROOM // LIFE 生活</p>
        <h1>Life Notes</h1>
        <p>Small memories from daily life: place, weather, mood, and a few quiet words. 记录普通日子里的小片段。</p>
      </div>
      <div class="life-counter mono">
        <strong>{life.length}</strong>
        <span>life note{life.length !== 1 ? 's' : ''}</span>
      </div>
    </div>

    <div class="life-timeline">
      {life.map((entry) => {
        const photo = entry.data.photos[0];
        return (
          <a href={`/life/${entry.slug}`} class="life-entry ink-panel">
            <div class="life-thumb" aria-hidden={!photo}>
              {photo ? <img src={mediaUrl(photo)} alt="" loading="lazy" /> : <span class="mono">{entry.data.type}</span>}
            </div>
            <div class="life-entry-meta mono">
              <span>{entry.data.type}</span>
              <time datetime={entry.data.date.toISOString()}>{entry.data.date.toLocaleDateString('en', { month: 'short', day: '2-digit', year: 'numeric' })}</time>
            </div>
            <div>
              <h2>{entry.data.title}</h2>
              <p>{entry.data.description ?? entry.data.location}</p>
              <div class="life-tags mono">
                {entry.data.location && <span>{entry.data.location}</span>}
                {entry.data.weather && <span>{entry.data.weather}</span>}
                {entry.data.mood && <span>{entry.data.mood}</span>}
              </div>
            </div>
          </a>
        );
      })}
      {life.length === 0 && (
        <p class="mono empty-life">NO LIFE NOTES YET / 还没有生活记录</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .life-shell {
    padding: 48px 0 96px;
  }

  .life-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 160px;
    gap: 24px;
    align-items: end;
    padding: clamp(22px, 4vw, 42px);
    margin-bottom: 18px;
    background:
      linear-gradient(135deg, color-mix(in oklch, var(--warm) 16%, var(--paper)), var(--paper) 58%),
      var(--paper);
  }

  .life-hero p:first-child {
    color: var(--warm);
    font-size: 12px;
    margin: 0 0 10px;
  }

  .life-hero h1 {
    font-size: clamp(2.4rem, 6vw, 5rem);
    line-height: 0.9;
    letter-spacing: 0;
    margin: 0;
  }

  .life-hero p:not(:first-child) {
    color: var(--muted);
    max-width: 620px;
    margin: 18px 0 0;
    line-height: 1.7;
  }

  .life-counter {
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: var(--surface);
    padding: 14px;
    text-align: right;
  }

  .life-counter strong {
    display: block;
    font-size: 3rem;
    line-height: 0.9;
  }

  .life-counter span {
    color: var(--muted);
    font-size: 12px;
  }

  .life-timeline {
    display: grid;
    gap: 12px;
    max-width: 900px;
  }

  .life-entry {
    display: grid;
    grid-template-columns: 156px 128px minmax(0, 1fr);
    gap: 20px;
    align-items: center;
    padding: 18px;
  }

  .life-thumb {
    display: grid;
    place-items: center;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: var(--surface-2);
    color: var(--muted);
    font-size: 11px;
  }

  .life-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .life-entry:hover {
    box-shadow: 5px 5px 0 var(--line-strong);
    transform: translate(-2px, -2px);
  }

  .life-entry-meta {
    display: grid;
    align-content: start;
    gap: 8px;
    color: var(--muted);
    font-size: 12px;
  }

  .life-entry-meta span {
    color: var(--warm);
    font-weight: 800;
  }

  .life-entry h2 {
    margin: 0;
    font-size: clamp(1.25rem, 3vw, 2rem);
    line-height: 1.05;
  }

  .life-entry p {
    color: var(--muted);
    margin: 8px 0 0;
    line-height: 1.6;
  }

  .life-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 14px;
  }

  .life-tags span {
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: var(--muted);
    font-size: 11px;
    padding: 5px 8px;
  }

  .empty-life {
    color: var(--muted);
    font-size: 12px;
  }

  @media (max-width: 720px) {
    .life-hero,
    .life-entry {
      grid-template-columns: 1fr;
    }

    .life-counter {
      text-align: left;
    }
  }
</style>
