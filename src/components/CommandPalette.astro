<div id="command-palette" hidden>
  <div style="position: fixed; inset: 0; background: rgba(0,0,0,.64); z-index: 20;"></div>
  <div class="panel" style="position: fixed; z-index: 21; top: 12vh; left: 50%; transform: translateX(-50%); width: min(560px, calc(100vw - 32px)); padding: 14px;">
    <p class="mono" style="color: var(--green); font-size: 12px; margin: 0 0 10px;">COMMAND PALETTE</p>
    <a href="/blog">Go to Blog</a><br />
    <a href="/life">Go to Life</a><br />
    <a href="/notes">Go to Notes</a><br />
    <a href="/lab">Go to Lab</a>
  </div>
</div>

<script>
  const palette = document.getElementById('command-palette');
  document.addEventListener('keydown', (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      if (palette) palette.hidden = !palette.hidden;
    }
    if (event.key === 'Escape' && palette) {
      palette.hidden = true;
    }
  });
</script>
