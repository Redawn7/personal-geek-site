---
const modules = [
  { href: '/blog', label: 'Blog', detail: 'Long-form signals' },
  { href: '/life', label: 'Life', detail: 'Photos and fragments' },
  { href: '/notes', label: 'Notes', detail: 'Garden seeds' },
  { href: '/lab', label: 'Lab', detail: 'Tools and demos' }
];
---

<section class="panel" style="padding: 16px;">
  <p class="mono" style="color: var(--green); font-size: 12px; margin: 0 0 12px;">MODULES</p>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px;">
    {modules.map((module) => (
      <a href={module.href} class="panel" style="display: block; padding: 14px; background: var(--surface-2);">
        <strong>{module.label}</strong>
        <p class="mono" style="color: var(--muted); margin: 8px 0 0; font-size: 12px;">{module.detail}</p>
      </a>
    ))}
  </div>
</section>
