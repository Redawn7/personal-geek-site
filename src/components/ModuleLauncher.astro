---
const modules = [
  { href: '/blog', label: 'Blog', detail: 'Long-form signals' },
  { href: '/life', label: 'Life', detail: 'Photos and fragments' },
  { href: '/notes', label: 'Notes', detail: 'Garden seeds' },
  { href: '/lab', label: 'Lab', detail: 'Tools and demos' }
];
---

<section class="ink-panel module-panel">
  <p class="mono">MODULES</p>
  <div class="module-grid-inner">
    {modules.map((module) => (
      <a href={module.href} class="module-link">
        <strong>{module.label}</strong>
        <span class="mono">{module.detail}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .module-panel {
    padding: 16px;
  }

  .module-panel > p {
    color: var(--green);
    font-size: 12px;
    margin: 0 0 12px;
  }

  .module-grid-inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px;
  }

  .module-link {
    display: block;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    padding: 14px;
  }

  .module-link:hover {
    border-color: var(--line-strong);
    box-shadow: 4px 4px 0 var(--line-strong);
    transform: translate(-2px, -2px);
  }

  .module-link span {
    color: var(--muted);
    display: block;
    margin: 8px 0 0;
    font-size: 12px;
  }
</style>
