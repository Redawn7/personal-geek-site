---
const items = [
  { label: 'Shanghai', tone: '#f6c177' },
  { label: 'Reading', tone: '#75e3b3' },
  { label: 'Building', tone: '#89a8ff' }
];
---

<section class="panel" style="padding: 16px;">
  <p class="mono" style="color: var(--warm); font-size: 12px; margin: 0 0 12px;">LIFE STRIP</p>
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;">
    {items.map((item) => (
      <div style={`min-height: 96px; border-radius: 6px; background: ${item.tone}; color: #090b0f; padding: 10px; display: flex; align-items: end; font-weight: 700; font-size: 0.9rem;`}>
        {item.label}
      </div>
    ))}
  </div>
</section>
