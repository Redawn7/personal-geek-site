---
const items = [
  { label: 'Shanghai', tone: 'var(--warm)' },
  { label: 'Reading', tone: 'var(--green)' },
  { label: 'Building', tone: 'var(--cyan)' }
];
---

<section class="ink-panel life-strip">
  <p class="mono">LIFE STRIP</p>
  <div>
    {items.map((item) => (
      <div style={`--tone: ${item.tone};`}>
        {item.label}
      </div>
    ))}
  </div>
</section>

<style>
  .life-strip {
    padding: 16px;
  }

  .life-strip > p {
    color: var(--warm);
    font-size: 12px;
    margin: 0 0 12px;
  }

  .life-strip > div {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .life-strip > div > div {
    min-height: 108px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background:
      linear-gradient(180deg, color-mix(in oklch, var(--tone) 34%, var(--paper)), var(--surface));
    color: var(--text);
    padding: 10px;
    display: flex;
    align-items: end;
    font-weight: 800;
    font-size: 0.9rem;
  }

  @media (max-width: 520px) {
    .life-strip > div {
      grid-template-columns: 1fr;
    }
  }
</style>
