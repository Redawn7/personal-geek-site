---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/dates';
import { mediaUrl } from '../lib/media';

type Props = {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  path?: string;
  image?: string;
  imageAlt?: string;
};
---

<BaseLayout title={Astro.props.title} description={Astro.props.description} path={Astro.props.path}>
  <article class="shell" style="padding: 56px 0 96px;">
    <header style="max-width: 760px; margin-bottom: 36px;">
      <p class="mono" style="color: var(--green); font-size: 12px; margin: 0 0 14px;">READING / 正在阅读</p>
      <h1 style="font-size: clamp(2.2rem, 7vw, 5.5rem); line-height: 0.96; letter-spacing: 0; margin: 0;">{Astro.props.title}</h1>
      {Astro.props.description && <p style="color: var(--muted); font-size: 1.1rem;">{Astro.props.description}</p>}
      {Astro.props.date && <p class="mono" style="color: var(--warm); font-size: 12px;">{formatDate(Astro.props.date)}</p>}
      {Astro.props.tags && (
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          {Astro.props.tags.map((tag) => <span class="mono" style="border: 1px solid var(--line); border-radius: 999px; padding: 4px 8px; color: var(--muted); font-size: 12px;">#{tag}</span>)}
        </div>
      )}
    </header>
    {Astro.props.image && (
      <figure class="content-cover">
        <img src={mediaUrl(Astro.props.image)} alt={Astro.props.imageAlt ?? Astro.props.title} loading="eager" />
      </figure>
    )}
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .content-cover {
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    margin: 0 0 36px;
    max-width: 940px;
    overflow: hidden;
    background: var(--surface);
  }

  .content-cover img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
</style>
